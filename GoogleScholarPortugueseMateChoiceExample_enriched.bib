@book{gomes2022capoeira_58,
  title = {CAPOEIRA EMANCIPATÓRIA (CE): UMA METODOLOGIA EMERGENTE NA FORMAÇÃO ACADÊMICA EM DANÇA, EM DIÁLOGO À CAPOEIRA REGIONAL},
  author = {Marcos Cezar Santos Gomes},
  year = {2022},
  journal = {Revista Gestão e Conhecimento},
  publisher = {South Florida Publishing LLC},
  volume = {16},
  doi = {10.55908/rgcv16n2-026},
  url = {https://books.google.com/books?hl=en&lr=&id=idJsEAAAQBAJ&oi=fnd&pg=PA2009&dq=%22escolha+de+parceiro%22+%22c%C3%B3pia%22%7C%22escolha+de+acasalamento%22+%22c%C3%B3pia%22%7C%22c%C3%B3pia+de+escolha%22%7C%22c%C3%B3pia+de+parceiro%22&ots=PJeydoTPsl&sig=V4XhzJVaqzlmbamUPE7KnmrY7PM},
  abstract = {Esse artigo tem como objetivo elucidar a Capoeira Emancipatória (CE) como uma vertente que se originou dos atravessamentos com a Capoeira Regional. Com a intenção de investigação da própria prática de ensino da capoeira para dançarinos na formação acadêmica em dança, a partir da sua implicação metodológica, experiência que perdura há dezoito anos, a pesquisa transitou pelo caminho qualitativo, bibliográfico e explicativo. A emancipação aqui tratada, postula que além de outras conquistas, a exemplo da livre escolha individual e coletiva, o direto de construir seus saberes, otimização da consciência política, Freire (2017), sinaliza para caminhos que emergem na desconstrução de ideias e ideais que oprimiram e negam as subjetividades afrodescendentes, (GOMES, 2017). Entende-se que a academia precisa repensar o modo de produção epistêmica que vem sendo ao longo de décadas, possibilitando, portanto, outros modos de fazer, sobretudo, que advém de pesquisadores negros, militantes da causa. Propor a capoeira com algumas novas terminologias dentro do conceito de capoeira emancipatória em que se defende é nutrir a formação acadêmica em dança com uma estética diferenciada, que representa um momento contemporâneo de redimensionamento cultural, assim como recuperação dos ideais africanos. Os resultados confirmam que a Capoeira Regional foi a matriz pela qual a Capoeira Emancipatória (CE) pôde ser iniciada no ensino acadêmico em dança.},
  note = {Query date: 2026-02-25 16:47:34},
}

