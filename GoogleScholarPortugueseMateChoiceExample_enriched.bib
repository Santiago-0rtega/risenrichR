@book{silva2020reflexões_67,
  title = {Reflexões acerca da questão dos resíduos sólidos em territórios indígenas},
  author = {Lucas Braga da Silva; Édi Augusto Benini},
  year = {2020},
  journal = {Revista Brasileira de Gestão Ambiental e Sustentabilidade},
  publisher = {Revista Brasileira de Gestao Ambiental e Sustentabilidade},
  volume = {7},
  doi = {10.21438/rbgas(2020)071724},
  url = {https://repositorio.ufsc.br/handle/123456789/78302},
  abstract = {A Política Nacional de Resíduos Sólidos apresenta o respeito às diversidades locais e regionais como um de seus princípios norteadores para a gestão integrada por todo o território brasileiro. Aponta ainda a elaboração de planos de gestão integrada como instrumento para a gestão e o gerenciamento neste contexto. A partir disso, a pesquisa objetiva discutir a respeito da gestão de resíduos sólidos em territórios indígenas brasileiros. Como procedimentos metodológicos, adotou-se a pesquisa documental e análise de conteúdo. Os dados revelam que a diversidade cultural e ambiental dos povos indígenas nem sempre é levada em consideração no contexto da gestão de resíduos sólidos em seus territórios. Conclui-se que é dado maior atenção aos resíduos sólidos produzidos em centros urbanos do que àqueles produzidos em territórios indígenas, no entanto, ambos carecem de uma efetiva política sustentável de ocupação, uso e gestão dos diversos espaços.},
  note = {Query date: 2026-02-25 16:47:34},
}

@misc{nogueira2024avaliação_68,
  title = {AVALIAÇÃO DE TESTE DE SCHIMER E TONOMETRIA OCULAR EM CÃES SUBMETIDOS A ANESTESIA DISSOCIATIVA PARA OVARIOHISTERECTOMIA E ORQUIECTOMIA ELETIVAS},
  author = {Mônica Capla Nogueira; Milena Friolani; Rafaela Cirota},
  year = {2024},
  journal = {REVISTA FOCO},
  publisher = {South Florida Publishing LLC},
  volume = {17},
  doi = {10.54751/revistafoco.v17n7-100},
  url = {https://search.proquest.com/openview/9f41f16e8965cc4182dae0b766d48b86/1?pq-origsite=gscholar&cbl=2026366&diss=y},
  abstract = {Com o objetivo de avaliar a produção de secreção lacrimal e a pressão intraocular de cães sob anestesia dissociativa para esterilização eletiva, foram realizados testes de Schirmer, com fita milimetrada específica e aferição da pressão intraocular, utilizando a técnica de tonometria de rebote. Para isso, 26 animais de diferentes raças, idades e sexo, foram examinados em dois diferentes momentos, sendo o primeiro momento imediatamente antes da sedação, no pré-operatório, seguido de outra mensuração, num segundo momento, após o procedimento cirúrgico (pós-operatório). Ao final do segundo momento de análise, somente 2 pacientes obtiveram valores satisfatórios (maior ou igual a 15mm/min) em ambos olhos no teste de Schirmer. Na técnica de tonometria de rebote, 3 pacientes apresentaram a PIO maior que 30mmHg e 7 menor que 15 mmHg, sendo esta diferença explicada pela associação de drogas anestésicas dissociativas. Tais alterações frente aos valores basais, revelam a importância da lubrificação ocular em pacientes anestesiados.},
}

