entries <- py$load_ris_file(ris_file)
length(entries)
entries[[1]]
titles <- vapply(
entries,
function(x) {
if (!is.null(x$title)) {
x$title
} else if (!is.null(x$primary_title)) {
x$primary_title
} else {
NA_character_
}
},
character(1)
)
titles <- titles[!is.na(titles) & nzchar(titles)]
length(titles)
head(titles, 10)
x <- enrich_refs(
input = titles,
input_type = "titles"
)
print(x)
summary(x)
as_tbl(x)
as_tbl(x, "candidates")
cand <- as_tbl(x, "candidates")
cand[, c("record_id", "title", "title_score", "confidence_score")]
View(cand)
fails <- x$failures
fails
resolved <- as_tbl(x)
resolved[is.na(resolved$title_resolved), c("record_id", "title")]
cand <- as_tbl(x, "candidates")
best_cand <- cand |>
dplyr::group_by(record_id) |>
dplyr::slice_max(order_by = confidence_score, n = 1, with_ties = FALSE) |>
dplyr::ungroup()
diag_tbl <- as_tbl(x) |>
dplyr::select(record_id, title, title_resolved, best_score, match_status) |>
dplyr::left_join(
best_cand |>
dplyr::select(record_id, candidate_title = title, candidate_doi = doi, candidate_year = year),
by = "record_id"
)
diag_tbl
x$failures
as_tbl(x) |>
dplyr::filter(is.na(title_resolved)) |>
dplyr::select(record_id, title)
fails <- x$failures
fails$title_original
fails$title_original[7]
nchar(fails$title_original[7])
